# Cost Management (Koku) API
LAGO_SYNC_KOKU_BASE_URL=http://localhost:8000/api/cost-management/v1
LAGO_SYNC_KOKU_IDENTITY=

# Lago API
LAGO_SYNC_LAGO_API_KEY=your_lago_api_key_here
LAGO_SYNC_LAGO_API_URL=http://localhost:3000

# Organization
LAGO_SYNC_ORG_ID=your_org_id_here

# Providers to sync (comma-separated)
LAGO_SYNC_PROVIDERS=["aws","azure","gcp","openshift"]

# OCP group_by dimensions
LAGO_SYNC_OCP_GROUP_BY=["cluster","project"]

# Include distributed overhead as separate OCP line items
LAGO_SYNC_OCP_INCLUDE_OVERHEAD=true
